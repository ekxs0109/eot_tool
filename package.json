{
  "name": "eot_tool",
  "private": true,
  "packageManager": "npm@10.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "build:benchmark-web": "turbo run build --filter=benchmark-web",
    "build:wasm": "make wasm",
    "dev:benchmark-web": "npm run dev --workspace benchmark-web",
    "pack-check": "turbo run pack-check",
    "test": "turbo run test",
    "verify:wasm": "make verify-wasm-artifacts"
  },
  "devDependencies": {
    "turbo": "2.9.6"
  }
}
