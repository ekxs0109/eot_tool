{
  "name": "fonttool-wasm",
  "version": "0.0.0",
  "description": "Publishable WASM package wrapper for eot_tool font conversion artifacts.",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    }
  },
  "files": [
    "dist",
    "vendor/wasm/*.js",
    "vendor/wasm/*.wasm"
  ],
  "scripts": {
    "build": "rm -rf ./dist && tsc -p tsconfig.build.json",
    "check:artifacts": "node ./scripts/check-artifacts.mjs",
    "pack-check": "node ./scripts/pack-check.mjs",
    "stage:wasm": "node ./scripts/stage-wasm.mjs",
    "test": "vitest run",
    "test:node-smoke": "npm run build && node ./test/node-smoke.mjs"
  },
  "engines": {
    "node": ">=24.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
